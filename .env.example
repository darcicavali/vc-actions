# vc-actions environment variables
# Copy this file to .env and fill in real values.

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Google Sheets (service account JSON, base64-encoded or path)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# GA4 (used by FunnelAgent / SEOAgent)
GA4_CREDENTIALS_JSON=
GA4_PROPERTY_ID=

# Shopify (used by SEOAgent for product meta reads)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Omnisend (used for weekly digest email)
OMNISEND_API_KEY=
OMNISEND_DIGEST_EVENT=vc_weekly_plan
OMNISEND_DIGEST_RECIPIENT=

# Runtime
VC_ACTIONS_TEST_MODE=false
VC_ACTIONS_DRY_RUN=false
# Seconds between specialist agents (rate-limit safety). Default 60.
VC_ACTIONS_INTER_AGENT_DELAY_SECONDS=60
